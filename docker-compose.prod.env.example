COMPOSE_PROJECT_NAME=archivist

ARCHIVIST_PUBLIC_PORT=65000
# Public hostname allowlist for forwarded-host validation. Use hostnames, not schemes.
ARCHIVIST_GATEWAY_PUBLIC_HOSTS=<specify>

ARCHIVIST_SQLITE_PATH=/data/archive.db
ARCHIVIST_DATA_DIR=/data

ARCHIVIST_Telegram__BotToken=<specify>
# Numeric Telegram user id allowed to submit URLs.
ARCHIVIST_Telegram__AllowedUserId=<specify>
ARCHIVIST_Telegram__WebhookSecret=<specify>

ARCHIVIST_AUTH_BOOTSTRAP_PASSWORD=<specify>

ARCHIVIST_JINA_API_KEY=<specify>
ARCHIVIST_LLM_PROVIDER=anthropic
ARCHIVIST_LLM_API_KEY=<specify>
ARCHIVIST_LLM_MODEL=claude-haiku-4-5-20251001
